{
  "manifest_version": 3,
  "name": "PasteDrops",
  "version": "1.0.0",
  "description": "Paste JSON from clipboard to auto-fill form fields using CSS selectors",
  "permissions": [
    "activeTab",
    "clipboardRead",
    "scripting"
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "PasteDrops - Fill form fields"
  },
  "commands": {
    "paste-drops": {
      "suggested_key": {
        "default": "Ctrl+Shift+V",
        "mac": "Command+Shift+V"
      },
      "description": "Paste clipboard JSON to form fields"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
